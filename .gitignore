# ==============================================================================
# Python
# ==============================================================================
__pycache__/
*.py[cod]
*.pyo
*.egg-info/
venv/
.venv/
env/
.pytest_cache/

# ==============================================================================
# Node / frontend
# ==============================================================================
node_modules/
dist/
build/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ==============================================================================
# Local env files (commit only *.example)
# ==============================================================================
.env
.env.local
.env.production
.env.development
backend/.env

# ==============================================================================
# IDE / OS
# ==============================================================================
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# ==============================================================================
# Vercel / HuggingFace / Claude local artifacts
# ==============================================================================
.vercel/
.huggingface/
.claude/

# ==============================================================================
# Backend runtime artifacts that should not be in git
# ==============================================================================
# SQLite DB is recreated and seeded on startup.
backend/data/sastra.db
# User uploads from local testing.
backend/data/uploads/

# ==============================================================================
# Local-only material not used at runtime
# ==============================================================================
# Raw scraped originals — superseded by backend/data/staff-photos/
SASTRA Staff Profile/
# Packaged macOS build (321MB)
SASTRA_Research_Finder_macOS.zip
MACOS_SETUP.md

# ==============================================================================
# Logs
# ==============================================================================
*.log

# NOTE: We deliberately do NOT ignore *.pkl, *.xlsx, or backend/data/cache/.
# These precomputed assets are required by the HF Spaces backend at startup
# (FAISS index, preprocessed embeddings, faculty rankings).
