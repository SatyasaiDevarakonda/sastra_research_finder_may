# API base URL — points at the FastAPI backend hosted on HuggingFace Spaces.
# Vite exposes any var prefixed with VITE_ to the client at build time.
#
# Local dev: leave VITE_API_URL unset. Vite proxies /api and /staff-photos
# to http://localhost:8000 (see vite.config.js).
#
# Production (Vercel): set this to your HF Space URL with /api appended.
# Example:
# VITE_API_URL=https://satyasaidevarakonda-sastra-research-finder.hf.space/api
VITE_API_URL=
